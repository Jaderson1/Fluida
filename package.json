{
  "name": "fluida",
  "private": true,
  "version": "0.0.0",
  "description": "Monorepo for Fluida - automatic, framework-agnostic responsive layouts",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.15.0+sha512.266f8957a30d2be6e9468e5e66bcdedd35a794175f71b067ba8504d686cce1d0c0f429b33c323c3c569ad4891e667574a49ff71d1b89a22cc66f13c65818c578",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "pretypecheck": "pnpm --filter @fluida/core run build",
    "typecheck": "pnpm -r run typecheck",
    "pretest": "pnpm --filter @fluida/core run build",
    "test": "pnpm -r run test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "demo:react": "pnpm --filter @fluida/react-demo dev",
    "demo:react:build": "pnpm --filter @fluida/react-demo build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.5",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}
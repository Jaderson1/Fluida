{
  "name": "@fluida/react",
  "version": "0.0.1",
  "description": "React adapter for Fluida — a Provider, viewport-based layout primitives, and a container-measuring FluidaAdaptiveGrid, all built on @fluida/core.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jaderson1/Fluida.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/Jaderson1/Fluida/tree/main/packages/react#readme",
  "bugs": {
    "url": "https://github.com/Jaderson1/Fluida/issues"
  },
  "keywords": [
    "react",
    "responsive",
    "layout",
    "breakpoints",
    "container-queries",
    "resize-observer",
    "hooks"
  ],
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "sideEffects": false,
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "@fluida/core": "workspace:*"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}